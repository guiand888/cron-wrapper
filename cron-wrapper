#!/usr/bin/env bash
set -euo pipefail

# ============================================================
# Generic Cron Script Wrapper
# 
# Executes a target script with environment variables and
# lock file management with timestamp-based stale detection.
#
# USAGE:
#   1. Copy this file to a new name (e.g., my-task-wrapper)
#   2. Edit the new file to set TARGET_SCRIPT and any needed variables
#   3. Make it executable: chmod +x my-task-wrapper
#   4. Call from cron or manually: ./my-task-wrapper
#
# ENVIRONMENT VARIABLES:
#   TARGET_SCRIPT             - Path to script to execute (default: ./script.sh)
#   STALE_LOCK_THRESHOLD_SECONDS - Lock timeout in seconds (default: 3600)
#   Any other variables        - Exported to the target script
# ============================================================

# --- CONFIGURATION ---
# Set these before using this wrapper

# Path to the script to execute (required)
TARGET_SCRIPT=${TARGET_SCRIPT:-./script.sh}

# Lock file timeout in seconds (optional, default: 3600 = 1 hour)
STALE_LOCK_THRESHOLD_SECONDS=${STALE_LOCK_THRESHOLD_SECONDS:-3600}

# Add any environment variables your target script needs below.
# Example:
# export DATABASE_URL=postgres://user:pass@host/db
# export LOG_LEVEL=info
#
# (Add your variables here)

# --- DERIVED VALUES ---
WRAPPER_NAME=$(basename "$0")
LOCK_FILE="/tmp/${WRAPPER_NAME}.lockfile"

# --- FUNCTIONS ---

# Log a message with timestamp
wrapper_log() {
    echo "[WRAPPER $(date +'%Y-%m-%dT%H:%M:%SZ')] $*"
}

# Cleanup lock file
cleanup() {
    rm -f "$LOCK_FILE"
}

# Check lock file
# Returns 0 if we should proceed (no lock or stale lock removed)
# Returns 1 if we should abort (recent lock exists)
check_lock() {
    if [ ! -f "$LOCK_FILE" ]; then
        return 0  # No lock file, proceed
    fi

    # Read timestamp from lock file
    local lock_timestamp
    lock_timestamp=$(head -n 1 "$LOCK_FILE" 2>/dev/null || echo "")

    # Validate timestamp format (ISO 8601 UTC: YYYY-MM-DDTHH:MM:SSZ)
    if [[ "$lock_timestamp" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$ ]]; then
        local lock_epoch
        lock_epoch=$(date -d "$lock_timestamp" +%s 2>/dev/null || echo "0")
        local current_epoch
        current_epoch=$(date +%s)
        local lock_age_seconds=$(( current_epoch - lock_epoch ))

        if [ "$lock_age_seconds" -gt "$STALE_LOCK_THRESHOLD_SECONDS" ]; then
            wrapper_log "Removing stale lock file (age: ${lock_age_seconds}s > ${STALE_LOCK_THRESHOLD_SECONDS}s)"
            rm -f "$LOCK_FILE"
            return 0  # Stale lock removed, proceed
        else
            wrapper_log "Lock file exists and is recent (age: ${lock_age_seconds}s). Aborting."
            return 1  # Lock is recent, abort
        fi
    else
        # Lock file exists but has invalid timestamp - treat as stale
        wrapper_log "Lock file has invalid timestamp format, treating as stale"
        rm -f "$LOCK_FILE"
        return 0  # Invalid lock removed, proceed
    fi
}

# Create lock file with timestamp
create_lock() {
    local timestamp
    timestamp=$(date -u +'%Y-%m-%dT%H:%M:%SZ')
    echo "$timestamp" > "$LOCK_FILE"
    wrapper_log "Lock file created: $LOCK_FILE"
}

# --- MAIN EXECUTION ---
main() {
    wrapper_log "Wrapper started: $WRAPPER_NAME"
    wrapper_log "Target script: $TARGET_SCRIPT"
    wrapper_log "Lock file: $LOCK_FILE"
    wrapper_log "Stale lock threshold: ${STALE_LOCK_THRESHOLD_SECONDS} seconds"

    # Validate target script exists
    if [ ! -f "$TARGET_SCRIPT" ]; then
        wrapper_log "ERROR: Target script not found: $TARGET_SCRIPT" >&2
        exit 1
    fi

    # Validate target script is executable
    if [ ! -x "$TARGET_SCRIPT" ]; then
        wrapper_log "ERROR: Target script is not executable: $TARGET_SCRIPT" >&2
        exit 1
    fi

    # Step 1: Check lock file
    wrapper_log "Checking lock file..."
    if ! check_lock; then
        wrapper_log "Aborting due to existing recent lock file"
        exit 0
    fi

    # Step 2: Create lock file
    create_lock

    # Step 3: Register cleanup trap
    trap cleanup EXIT

    # Step 4: Execute the target script
    wrapper_log "Executing target script: $TARGET_SCRIPT"

    # Execute script (output goes to stdout/stderr of wrapper)
    "$TARGET_SCRIPT"
    local exit_code=$?

    # Step 5: Final log
    if [ "$exit_code" -eq 0 ]; then
        wrapper_log "Target script completed successfully (exit code: $exit_code)"
    else
        wrapper_log "Target script failed (exit code: $exit_code)" >&2
    fi

    # Cleanup happens via trap
    exit $exit_code
}

main "$@"
